{
  "name": "@harmoni/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node node_modules/vite/bin/vite.js build",
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"pnpm --filter @harmoni/web dev\" \"node node_modules/wait-on/bin/wait-on http://localhost:3000 && node node_modules/electron/cli.js . --no-sandbox\"",
    "start": "electron . --no-sandbox",
    "lint": "echo 'lint desktop'"
  },
  "dependencies": {
    "electron": "^33.2.0"
  },
  "devDependencies": {
    "wait-on": "^8.0.1",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "@vitejs/plugin-react": "^4.3.4"
  }
}