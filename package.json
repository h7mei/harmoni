{
  "name": "harmoni",
  "version": "0.1.0",
  "private": true,
  "description": "Linear-inspired real-time collaboration platform",
  "pnpm": {
    "overrides": {
      "rimraf": "5.0.5",
      "glob": "10.5.0"
    }
  },
  "scripts": {
    "prepare": "husky",
    "setup": "node scripts/setup.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @harmoni/web dev",
    "dev:backend": "pnpm --filter @harmoni/backend dev",
    "dev:desktop": "pnpm --filter @harmoni/desktop dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @harmoni/backend db:migrate",
    "db:generate": "pnpm --filter @harmoni/backend db:generate",
    "db:studio": "pnpm --filter @harmoni/backend db:studio"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
